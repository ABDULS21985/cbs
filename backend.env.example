# Backend ledger settlement configuration
# Wallet posting requires an explicit settlement GL.
CBS_LEDGER_WALLET_SETTLEMENT_GL=

# Remittance posting can use a dedicated settlement GL or fall back to external clearing.
CBS_LEDGER_EXTERNAL_CLEARING_GL=
CBS_LEDGER_REMITTANCE_SETTLEMENT_GL=
CBS_LEDGER_SAVINGS_GOAL_GL=
CBS_LEDGER_OVERDRAFT_ASSET_GL=
CBS_LEDGER_TRADE_FINANCE_SETTLEMENT_GL=
CBS_LEDGER_TRADE_FINANCE_COMMISSION_GL=

# ─────────────────────────────────────────────────────────────────────────────
# Load-test profile env vars (ONLY for isolated load-test environments)
# ⚠️  NEVER set these in production — the loadtest Spring profile disables ALL auth.
# ─────────────────────────────────────────────────────────────────────────────
# CBS_LOADTEST_DB_URL=jdbc:postgresql://loadtest-db:5432/cbs_loadtest
# CBS_LOADTEST_DB_USERNAME=cbs_loadtest
# CBS_LOADTEST_DB_PASSWORD=                  # Required — no default; app won't start without it
# CBS_LOADTEST_REDIS_HOST=loadtest-redis
# CBS_LOADTEST_REDIS_PORT=6379
